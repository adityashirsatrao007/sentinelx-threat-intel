# ─── SentinelX Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=SentinelX
APP_VERSION=1.0.0
DEBUG=false
ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# For local Docker: postgresql://sentinelx:sentinelx_pass@postgres:5432/sentinelx_db
# For Neon cloud:
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require

# ─── Redis & Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── ML Models ────────────────────────────────────────────────────────────────
NLP_MODEL_NAME=distilbert-base-uncased
WHISPER_MODEL_SIZE=base
ML_CACHE_DIR=./ml_cache
USE_GPU=false

# ─── Google OAuth2 / Gmail Integration ────────────────────────────────────────
# Setup Steps:
#  1. Go to https://console.cloud.google.com/
#  2. Create a project → Enable Gmail API
#  3. Create OAuth2 credentials (Web Application type)
#  4. Set Authorized Redirect URI to: http://localhost:8000/api/v1/gmail/callback
#  5. Paste Client ID and Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/gmail/callback

# ─── Gmail Polling ────────────────────────────────────────────────────────────
# Interval in seconds between Gmail polling cycles (default: 60)
GMAIL_POLL_INTERVAL_SECONDS=60

# ─── External APIs (Optional) ─────────────────────────────────────────────────
# VIRUSTOTAL_API_KEY=your_virustotal_key_here
# PHISHTANK_API_KEY=your_phishtank_key_here

# ─── Risk Thresholds ──────────────────────────────────────────────────────────
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_MEDIUM=60
RISK_THRESHOLD_HIGH=85
ALERT_TRIGGER_THRESHOLD=61

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
